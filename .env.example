# EBE Commerce — real-data credentials.
# Copy to ".env" (which is git-ignored) and fill in. NEVER commit real keys.
# See SETUP.md for exactly how to obtain each value.

# ── Keepa (sourcing data — instant, get this first) ──────────────────────────
KEEPA_API_KEY=

# ── Amazon Selling-Partner API (your listings / prices / FBA stock) ──────────
SPAPI_REFRESH_TOKEN=
SPAPI_CLIENT_ID=
SPAPI_CLIENT_SECRET=
# region: na | eu | fe   ·   marketplace: us, uk, de, ...
SPAPI_REGION=na
SPAPI_MARKETPLACE=us

# ── Amazon Advertising API (ad spend / sales / ACOS) ─────────────────────────
ADS_REFRESH_TOKEN=
ADS_CLIENT_ID=
ADS_CLIENT_SECRET=
ADS_PROFILE_ID=
ADS_REGION=na

# ── Anthropic (the AI BRAIN — `--ai` flag; needs `pip install anthropic`) ────
ANTHROPIC_API_KEY=

# ── eBay Browse API (cross-channel arbitrage PriceSource; developer.ebay.com) ─
EBAY_OAUTH_TOKEN=

# ── Shopify (your own-brand DTC store — stock & price sync) ──────────────────
# store = the part before .myshopify.com · token = custom-app Admin API token (shpat_...)
SHOPIFY_STORE=
SHOPIFY_TOKEN=

# ── Square (venue POS — real sales → consumption → auto-reorder) ─────────────
SQUARE_TOKEN=
SQUARE_LOCATION_ID=

# ── Stripe (real revenue + available balance → the brief & cash forecast) ────
# secret key from Stripe → Developers → API keys (sk_live_... or sk_test_...)
STRIPE_SECRET_KEY=
