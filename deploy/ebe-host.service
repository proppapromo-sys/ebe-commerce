[Unit]
Description=EBE Command — hosted multi-tenant SaaS
After=network.target

[Service]
Type=simple
User=ebe
WorkingDirectory=/opt/ebe-commerce
# CHANGE these two before enabling. HOST_SECRET signs login cookies; OWNER_PASSWORD guards /admin.
Environment=EBE_HOST_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING
Environment=EBE_OWNER_PASSWORD=CHANGE_ME_OWNER_PASSWORD
# Optional live data for tenants that use it:
# Environment=KEEPA_API_KEY=...
# Environment=ANTHROPIC_API_KEY=...
ExecStart=/usr/bin/python3 -m ebe host --port 8080
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
